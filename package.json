{
  "name": "synapse",
  "version": "1.0.0",
  "description": "个人 AI 中间层 — 工具调用、记忆系统、插件生态",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:rust": "cd rust-vector && npm run build",
    "lint": "eslint .",
    "pm2:start": "pm2 start server.js --name synapse",
