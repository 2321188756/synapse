    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
